# RewardHub — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase — get these from your project's Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth Client ID (optional — Supabase handles OAuth redirect)
# Only needed if you configure Google provider manually outside of Supabase.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
